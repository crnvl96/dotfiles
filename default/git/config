[github]
  user = crnvl96
[gpg]
  format = ssh
[user]
  name = "Adran Carnavale"
  email = adran@hey.com
  signingkey = ~/.ssh/id_ed25519.pub
[commit]
  verbose = true
  gpgsign = true
[core]
  editor = $EDITOR
  excludesfile = ~/.local/share/dotfiles/default/git/.gitignore_global
[init]
  defaultBranch = main
[diff]
  algorithm = patience
  compactionHeuristic = true
[fetch]
  prune = true
  all = true
[pull]
  rebase = false
[push]
  autoSetupRemote = true
[merge]
  conflictstyle = zdiff3
