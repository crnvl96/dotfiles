# theme = NvimDark

font-family = Berkeley Mono
font-size = 13
adjust-cell-width = -5%
adjust-cell-height = 20%
adjust-underline-position = 6
adjust-underline-thickness = 40%
adjust-cursor-thickness = 150%

confirm-close-surface = false

shell-integration-features = cursor

gtk-adwaita = false
gtk-titlebar = false

keybind = alt+one=goto_tab:1
keybind = alt+two=goto_tab:2
keybind = alt+three=goto_tab:3
keybind = alt+four=goto_tab:4
keybind = alt+five=goto_tab:5
keybind = alt+six=goto_tab:6
keybind = alt+seven=goto_tab:7
keybind = alt+eight=goto_tab:8
keybind = alt+nine=goto_tab:9
keybind = alt+zero=goto_tab:10

keybind = alt+t=new_tab
keybind = alt+q=close_surface
keybind = alt+equal=increase_font_size:1
keybind = alt+minus=decrease_font_size:1
keybind = alt+zero=reset_font_size

keybind = alt+v=new_split:right
keybind = alt+s=new_split:down
keybind = alt+k=goto_split:top
keybind = alt+j=goto_split:bottom
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right

keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

keybind = alt+shift+v=write_screen_file:paste

# vim set ft=conf
