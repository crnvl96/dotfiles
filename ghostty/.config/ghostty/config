theme = light:Kanagawa Lotus,dark:Kanagawa Wave
font-family = "JetBrainsMonoNerdFont"
font-size = 12

window-theme = ghostty
window-inherit-working-directory = true
working-directory = inherit
window-padding-x = 10,0
window-padding-y = 10,0

cursor-style-blink = false
shell-integration-features = no-cursor

confirm-close-surface = false

keybind = alt+one=goto_tab:1
keybind = alt+two=goto_tab:2
keybind = alt+three=goto_tab:3
keybind = alt+four=goto_tab:4
keybind = alt+five=goto_tab:5
keybind = alt+six=goto_tab:6
keybind = alt+seven=goto_tab:7
keybind = alt+eight=goto_tab:8
keybind = alt+nine=goto_tab:9

keybind = alt+shift+comma=reload_config

keybind = alt+shift+t=new_tab
keybind = alt+shift+c=close_surface

keybind = alt+shift+v=new_split:right
keybind = alt+shift+s=new_split:down

keybind = alt+shift+k=goto_split:top
keybind = alt+shift+j=goto_split:bottom
keybind = alt+shift+h=goto_split:left
keybind = alt+shift+l=goto_split:right

keybind = alt+shift+up=resize_split:up,5
keybind = alt+shift+down=resize_split:down,5
keybind = alt+shift+right=resize_split:right,20
keybind = alt+shift+left=resize_split:left,20

keybind = alt+equal=increase_font_size:1
keybind = alt+minus=decrease_font_size:1
keybind = alt+zero=reset_font_size

keybind = ctrl+shift+p=toggle_command_palette

