{
  "telemetry.telemetryLevel": "off",
  "breadcrumbs.enabled": false,

  "ruff.format.backend": "uv",

  "search.useIgnoreFiles": true,
  "search.exclude": {
    "**/.venv": true
  },

  // languages.
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[skill]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },

  // chat
  "chat.fontSize": 16,
  "chat.editor.fontSize": 15,

  // git
  "git.confirmSync": false,
  "git.autofetch": true,

  // aws
  "aws.cloudformation.telemetry.enabled": false,
  "aws.telemetry": false,

  // diff
  "diffEditor.renderSideBySideInlineBreakpoint": 1200,

  // claude
  "claudeCode.preferredLocation": "panel",
  "claudeCode.useTerminal": true,

  // vim
  "vim.easymotion": false,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.hlsearch": true,
  "vim.visualstar": true,
  "vim.highlightedyank.enable": true,
  "vim.smartRelativeLine": true,
  "vim.leader": "<space>",

  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-s>": false,
    "<C-p>": false
  },

  "extensions.experimental.affinity": {
    "vscodevim.vim": 1
  },

  "vim.insertModeKeyBindings": [
    { "before": ["j", "k"], "after": ["<Esc>"] },
    { "before": ["k", "j"], "after": ["<Esc>"] }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [],
  "vim.normalModeKeyBindings": [
    {
      "before": [":"],
      "commands": ["workbench.action.showCommands"],
      "silent": true
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["p"],
      "after": ["p", "g", "v", "y"]
    }
  ],

  // terminal.
  "terminal.integrated.sendKeybindingsToShell": true,

  // workbench settings.
  "workbench.startupEditor": "terminal",
  "workbench.tree.indent": 20,
  "workbench.iconTheme": "vscode-jetbrains-icon-theme-2023-auto",
  "workbench.colorTheme": "One Dark Pro",
  "workbench.editor.highlightModifiedTabs": true,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.layoutControl.enabled": false,

  // window
  "window.zoomLevel": 0.5,
  "window.commandCenter": false,
  "window.customTitleBarVisibility": "never",

  // editor settings.
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontLigatures": true,
  "editor.letterSpacing": 0.3,
  "editor.lineHeight": 1.6,
  "editor.hover.delay": 500,
  "editor.fontSize": 14,
  "editor.hover.enabled": "on",
  "editor.lightbulb.enabled": "off",
  "editor.selectionHighlight": false,
  "editor.overviewRulerBorder": false,
  "editor.inlayHints.enabled": "off",
  "editor.renderLineHighlight": "none",
  "editor.showFoldingControls": "always",
  "editor.guides.bracketPairsHorizontal": false,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.stickyScroll.enabled": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": { "source.fixAll.oxc": "always" },
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 120,
  "editor.cursorBlinking": "solid"
}
