{
  "mcpServers": {
    "fetch": {
      "args": ["mcp-server-fetch"],
      "command": "uvx",
      "disabled": false
    },
    "inkdrop": {
      "env": {
        "INKDROP_LOCAL_PASSWORD": "inkdrop",
        "INKDROP_LOCAL_SERVER_URL": "http://localhost:19840",
        "INKDROP_LOCAL_USERNAME": "inkdrop"
      },
      "command": "npx",
      "args": ["-y", "@inkdropapp/mcp-server"]
    }
  }
}

