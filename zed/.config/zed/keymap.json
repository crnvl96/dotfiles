[
    {
        "context": "Pane",
        "bindings": {
            "ctrl-w": null,
            "ctrl-w c": "pane::CloseActiveItem"
        }
    },
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-w h": ["workspace::ActivatePaneInDirection", "Left"],
            "ctrl-w l": ["workspace::ActivatePaneInDirection", "Right"],
            "ctrl-w k": ["workspace::ActivatePaneInDirection", "Up"],
            "ctrl-w j": ["workspace::ActivatePaneInDirection", "Down"],
            "ctrl-t": "workspace::NewTerminal"
        }
    },
    {
        "context": "Dock",
        "bindings": {
            "ctrl-w h": ["workspace::ActivatePaneInDirection", "Left"],
            "ctrl-w l": ["workspace::ActivatePaneInDirection", "Right"],
            "ctrl-w k": ["workspace::ActivatePaneInDirection", "Up"],
            "ctrl-w j": ["workspace::ActivatePaneInDirection", "Down"],
            "ctrl-t": "workspace::NewTerminal"
        }
    },
    {
        "context": "Editor && vim_mode == normal && !VimWaiting && !VimCount",
        "bindings": {
            "0": ["vim::StartOfLine", { "displayLines": true }],
            "$": ["vim::EndOfLine", { "displayLines": true }]
        }
    },
    {
        "context": "Editor && showing_completions",
        "bindings": {
            "ctrl-y": "editor::ConfirmCompletion"
        }
    },
    {
        "context": "Editor && vim_mode == insert && !VimWaiting && !VimCount && !menu",
        "bindings": {
            "ctrl-s": ["workspace::SendKeystrokes", "escape : w enter"],
            "ctrl-n": "editor::ShowCompletions",
            "ctrl-p": "editor::ShowCompletions"
        }
    },
    {
        "context": "Editor && vim_mode == visual && !VimWaiting && !VimCount && !menu",
        "bindings": {
            "<": "editor::Outdent",
            ">": "editor::Indent"
        }
    },
    {
        "context": "Editor && (showing_code_actions || showing_completions)",
        "bindings": {
            "up": "editor::ContextMenuPrev",
            "k": "editor::ContextMenuPrev",
            "down": "editor::ContextMenuNext",
            "j": "editor::ContextMenuNext",
            "shift-k": "editor::ContextMenuFirst",
            "shift-j": "editor::ContextMenuLast"
        }
    },
    {
        "context": "Search",
        "bindings": {
            "alt-c": "search::ToggleCaseSensitive",
            "alt-r": "search::ToggleRegex"
        }
    },
    {
        "context": "Editor && VimControl && !VimWaiting && !menu",
        "bindings": {
            "alt-j": "editor::AddSelectionBelow",
            "alt-k": "editor::AddSelectionAbove",
            "]]": "editor::SelectLargerSyntaxNode",
            "[[": "editor::SelectSmallerSyntaxNode",
            "space f f": "file_finder::Toggle",
            "space f b": "tab_switcher::Toggle",
            "space f g": "pane::DeploySearch",
            "g i": "editor::GoToImplementation",
            "g y": "editor::GoToTypeDefinition",
            "g r": "editor::FindAllReferences",
            "j": ["vim::Down", { "displayLines": true }],
            "k": ["vim::Up", { "displayLines": true }],
            "alt-a": "search::ToggleCaseSensitive",
            "alt-r": "search::ToggleRegex"
        }
    },
    {
        "context": "TabSwitcher",
        "bindings": {
            "k": "menu::SelectPrev",
            "j": "menu::SelectNext",
            "x": "tab_switcher::CloseSelectedItem"
        }
    }
]
