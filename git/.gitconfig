[github]
  user = crnvl96
[init]
  defaultBranch = main
[core]
  editor = $EDITOR
  excludesfile = ~/.gitignore_global
[commit]
  gpgsign = true
[gpg]
  format = ssh
[alias]
  co = checkout
  br = branch
  ci = commit
  st = status
[pull]
  rebase = true
[init]
  defaultBranch = master
[user]
  name = Adran Carnavale
  email = adran@hey.com
  signingkey = ~/.ssh/id_ed25519.pub
