[user]
    name = Adran Carnavale
    email = adran.carnavale@gmail.com
    signingkey = ~/.ssh/id_ed25519.pub
[github]
    user = crnvl96
[init]
    defaultBranch = main
[core]
    editor = $EDITOR
    excludesfile = ~/.gitignore_global
[commit]
    gpgsign = true
[gpg]
    format = ssh
[alias]
    st = status
    c = commit
    dt = difftool -y
[pull]
    rebase = false
[fetch]
    prune = true
[merge]
    conflictstyle = diff3
[diff]
  tool = nvim_difftool
[difftool "nvim_difftool"]
  cmd = nvim -c \"packadd nvim.difftool\" -d \"$LOCAL\" \"$REMOTE\"
