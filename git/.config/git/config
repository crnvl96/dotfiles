[github]
	user = crnvl96
[gpg]
  format = ssh
[user]
  name = "Adran Carnavale"
  email = contact@adrancarnavale.com
  signingkey = ~/.ssh/sign.pub
[commit]
  verbose = true
  gpgsign = true
[core]
  editor = $EDITOR
  excludesfile = ~/.config/git/.gitignore_global
	pager = delta
[interactive]
    diffFilter = delta --color-only
[init]
  defaultBranch = main
[diff]
  algorithm = patience
  compactionHeuristic = true
[fetch]
	prune = true
	all = true
[pull]
	rebase = true
[push]
	autoSetupRemote = true
[merge]
	conflictstyle = zdiff3
[delta]
	navigate = true
	dark = true
